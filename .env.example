# ═══════════════════════════════════════════════════════════════
#  .env.example — BALAJI Photo Frames
#
#  STEPS:
#  1. Is file ko copy karo:  cp .env.example .env
#  2. .env mein apni real values daalo
#  3. .env KABHI GitHub pe push mat karo (already in .gitignore)
#
#  DEV (local): IntelliJ/VSCode mein .env plugin use karo
#               Ya: export $(cat .env | xargs) && mvn spring-boot:run
#
#  PROD (GCP):  GCP VM pe: source /etc/balaji.env
#               Ya systemd service mein EnvironmentFile set karo
# ═══════════════════════════════════════════════════════════════

# ── Razorpay (get from dashboard.razorpay.com) ────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Admin Login ───────────────────────────────────────────────
ADMIN_USERNAME=balaji_admin
ADMIN_PASSWORD=YourStrongPassword@2024

# ── Database (prod only — dev uses H2 automatically) ─────────
DB_URL=jdbc:mysql://localhost:3306/balajiframes?useSSL=false&serverTimezone=Asia/Kolkata
DB_USERNAME=balaji_db_user
DB_PASSWORD=YourDBPassword@123

# ── Upload Directory ──────────────────────────────────────────
# Dev:  /tmp/balaji-dev-uploads
# Prod: /opt/balaji/uploads
UPLOAD_DIR=/tmp/balaji-dev-uploads
